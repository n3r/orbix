# ──────────────────────────────────────────────────────────────────
# Orbix Production Environment — Example
#
# Copy this file to deploy/.env (or paste into Portainer's Env tab).
# Never commit deploy/.env to git.
# ──────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# Password for the postgres container (used in both POSTGRES_PASSWORD and DATABASE_URL)
POSTGRES_PASSWORD=change-me-strong-password

# Full connection string — host must be "postgres" (the compose service name)
DATABASE_URL=postgresql://orbix:change-me-strong-password@postgres:5432/orbix

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Session secret (REQUIRED) ─────────────────────────────────────
# Generate with: openssl rand -base64 32
# Must be at least 32 characters.
SESSION_SECRET=replace-with-openssl-rand-base64-32-output

# ── Web / API origin ──────────────────────────────────────────────
# Public URL users access the web UI from (your NAS IP or hostname + port).
# Must match the HOST:PORT that browser requests arrive on.
# Examples:
#   http://192.168.1.100:8080
#   http://nas.local:8080
#   https://orbix.example.com  (if behind a TLS reverse proxy)
WEB_ORIGIN=http://YOUR-NAS-IP:8080

# Web UI published port (host port; container always listens on this port too)
WEB_PORT=8080

# API published port on the host (used for direct API access / debugging)
# The API is also accessible via the web proxy at /api/*
API_PORT_HOST=8081

# ── Media library ─────────────────────────────────────────────────
# Absolute path on the NAS host to the root of your media collection.
# Mounted read-only inside containers at /media
# Example: /volume1/media  (Synology)  or  /mnt/storage/media
ORBIX_MEDIA_PATH=/path/to/your/media

# ── Data directories (inside container — map to named volumes) ─────
# These should match the volume mounts in portainer-stack.yml.
# Change only if you customise the volume paths.
METADATA_DIR=/data/metadata
TRANSCODE_DIR=/data/transcode

# ── Embedding model ────────────────────────────────────────────────
# The bge-small-en-v1.5 model is baked into the API image at build time.
# MODELS_DIR points to the baked location inside the image.
# Only change this if you mount an external orbix-models volume instead.
MODELS_DIR=/app/data/models
EMBEDDINGS_ENABLED=true

# ── Node environment ──────────────────────────────────────────────
NODE_ENV=production
