FROM node:22-bookworm-slim
RUN apt-get update && apt-get install -y ffmpeg curl && rm -rf /var/lib/apt/lists/*
RUN corepack enable
WORKDIR /app
# Copy only manifests first so the (slow) install layer stays cached until a
# package.json / lockfile changes — source edits no longer bust the install.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/api/package.json apps/api/
COPY apps/web/package.json apps/web/
COPY packages/config/package.json packages/config/
COPY packages/core/package.json packages/core/
COPY packages/db/package.json packages/db/
COPY packages/ui/package.json packages/ui/
RUN pnpm install --frozen-lockfile
COPY . .
RUN pnpm --filter @orbix/db exec prisma generate
EXPOSE 1061
CMD ["sh", "-c", "pnpm --filter @orbix/db exec prisma migrate deploy && pnpm --filter @orbix/api dev"]
